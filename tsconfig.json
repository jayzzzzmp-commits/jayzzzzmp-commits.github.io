import { useEffect, useState, useMemo } from "react";
import { Link } from "react-router-dom";
import { Calendar } from "@/components/ui/calendar";

const dailyQuotes = [
  { text: "生活不是等待风暴过去，而是学会在雨中跳舞。", author: "维维安·格林" },
  { text: "千里之行，始于足下。", author: "老子" },
  { text: "不积跬步，无以至千里。", author: "荀子" },
  { text: "学而不思则罔，思而不学则殆。", author: "孔子" },
  { text: "知之者不如好之者，好之者不如乐之者。", author: "孔子" },
  { text: "温故而知新，可以为师矣。", author: "孔子" },
  { text: "人生天地之间，若白驹过隙，忽然而已。", author: "庄子" },
];

const recentPosts = [
  {
    date: "2026-03-28",
    title: "开始记录我的生活",
    summary: "今天我搭建了这个个人博客，希望能坚持记录生活中的点滴。",
  },
  {
    date: "2026-03-27",
    title: "关于极简主义",
    summary: "少即是多。在设计和生活中，专注于真正重要的内容。",
  },
  {
    date: "2026-03-25",
    title: "春天来了",
    summary: "窗外的樱花开了，用相机记录下这一刻。",
  },
];

const featuredPhotos = Array.from({ length: 4 }, (_, i) => i);

const favoriteAlbums = [
  { title: "OK Computer", artist: "Radiohead" },
  { title: "To Pimp a Butterfly", artist: "Kendrick Lamar" },
  { title: "Blonde", artist: "Frank Ocean" },
  { title: "In Rainbows", artist: "Radiohead" },
];

const Index = () => {
  const [time, setTime] = useState(new Date());
  const [calendarDate, setCalendarDate] = useState<Date | undefined>(new Date());

  useEffect(() => {
    const timer = setInterval(() => setTime(new Date()), 1000);
    return () => clearInterval(timer);
  }, []);

  const greeting = (() => {
    const h = time.getHours();
    if (h < 6) return "夜深了";
    if (h < 12) return "早上好";
    if (h < 18) return "下午好";
    return "晚上好";
  })();

  const timeStr = time.toLocaleTimeString("en-US", { hour12: false });

  const todayQuote = useMemo(() => {
    const dayOfYear = Math.floor(
      (Date.now() - new Date(new Date().getFullYear(), 0, 0).getTime()) / 86400000
    );
    return dailyQuotes[dayOfYear % dailyQuotes.length];
  }, []);

  return (
    <div className="space-y-10">
      {/* Hero */}
      <div className="space-y-1">
        <p className="text-2xl text-muted-foreground font-mono tracking-wider">{timeStr}</p>
        <h1 className="text-3xl font-bold tracking-tight text-foreground">
          {greeting}，欢迎来到我的小站 ☕
        </h1>
        <p className="text-muted-foreground leading-relaxed">
          这里记录我的学习日记、人生领悟，和一些美好的收藏。
        </p>
      </div>

      {/* Quote + Calendar */}
      <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {/* Daily Quote */}
        <div className="rounded-xl bg-card/80 border border-border/50 p-5 flex flex-col justify-center space-y-3">
          <p className="text-xs text-muted-foreground uppercase tracking-widest">每日一言</p>
          <blockquote className="text-base text-foreground leading-relaxed italic">
            "{todayQuote.text}"
          </blockquote>
          <p className="text-sm text-muted-foreground text-right">— {todayQuote.author}</p>
        </div>

        {/* Mini Calendar */}
        <div className="rounded-xl bg-card/80 border border-border/50 p-2 flex items-center justify-center">
          <Calendar
            mode="single"
            selected={calendarDate}
            onSelect={setCalendarDate}
            className="p-0 pointer-events-auto"
          />
        </div>
      </div>

      {/* Recent Posts */}
      <section className="space-y-4">
        <div className="flex items-center justify-between">
          <h2 className="text-lg font-semibold text-foreground">最近文章</h2>
          <Link
            to="/blog"
            className="text-xs text-muted-foreground hover:text-foreground transition-colors"
          >
            查看全部 →
          </Link>
        </div>
        <div className="space-y-3">
          {recentPosts.map((post, i) => (
            <Link
              to="/blog"
              key={i}
              className="block rounded-xl bg-card/80 border border-border/50 p-4 hover:border-border hover:shadow-sm transition-all duration-200"
            >
              <time className="text-xs text-muted-foreground">{post.date}</time>
              <h3 className="mt-1 text-base font-medium text-foreground">
                {post.title}
              </h3>
              <p className="mt-1 text-sm text-muted-foreground line-clamp-1">
                {post.summary}
              </p>
            </Link>
          ))}
        </div>
      </section>

      {/* Photo Picks */}
      <section className="space-y-4">
        <div className="flex items-center justify-between">
          <h2 className="text-lg font-semibold text-foreground">近期摄影</h2>
          <Link
            to="/gallery"
            className="text-xs text-muted-foreground hover:text-foreground transition-colors"
          >
            查看全部 →
          </Link>
        </div>
        <div className="grid grid-cols-2 gap-3 sm:grid-cols-4">
          {featuredPhotos.map((i) => (
            <div
              key={i}
              className="aspect-square rounded-xl bg-muted/50 border border-border/40 flex items-center justify-center text-muted-foreground text-xs hover:border-border transition-colors duration-200"
            >
              Photo
            </div>
          ))}
        </div>
      </section>

      {/* Album Picks */}
      <section className="space-y-4">
        <div className="flex items-center justify-between">
          <h2 className="text-lg font-semibold text-foreground">收藏专辑</h2>
          <Link
            to="/gallery"
            className="text-xs text-muted-foreground hover:text-foreground transition-colors"
          >
            查看全部 →
          </Link>
        </div>
        <div className="grid grid-cols-2 gap-3 sm:grid-cols-4">
          {favoriteAlbums.map((album, i) => (
            <div key={i} className="group space-y-1.5">
              <div className="aspect-square rounded-lg bg-muted/50 border border-border/40 flex items-center justify-center text-muted-foreground text-xs group-hover:border-border group-hover:shadow-sm transition-all duration-200">
                Cover
              </div>
              <div className="px-0.5">
                <p className="text-sm font-medium text-foreground truncate leading-tight">
                  {album.title}
                </p>
                <p className="text-xs text-muted-foreground truncate">
                  {album.artist}
                </p>
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  );
};

export default Index;
