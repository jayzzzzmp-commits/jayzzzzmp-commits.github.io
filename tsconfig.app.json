import { useState } from "react";

type TabType = "photos" | "albums";

const photos = Array.from({ length: 9 }, (_, i) => ({
  id: i,
  label: `Photo ${i + 1}`,
  // Varying aspect ratios for masonry effect
  tall: [0, 3, 5, 7].includes(i),
}));

const albums = Array.from({ length: 8 }, (_, i) => ({
  id: i,
  title: `Album Title ${i + 1}`,
  artist: `Artist ${i + 1}`,
}));

const Gallery = () => {
  const [activeTab, setActiveTab] = useState<TabType>("photos");

  return (
    <div className="space-y-6">
      <div>
        <h1 className="text-3xl font-bold tracking-tight text-foreground">Gallery</h1>
        <p className="mt-1 text-muted-foreground">收藏光影与旋律。</p>
      </div>

      {/* Tab switcher — pill style */}
      <div className="flex gap-1 rounded-full bg-muted/80 p-1 w-fit backdrop-blur-sm">
        <button
          onClick={() => setActiveTab("photos")}
          className={`rounded-full px-5 py-1.5 text-sm font-medium transition-all duration-300 ${
            activeTab === "photos"
              ? "bg-card text-foreground shadow-sm"
              : "text-muted-foreground hover:text-foreground"
          }`}
        >
          摄影
        </button>
        <button
          onClick={() => setActiveTab("albums")}
          className={`rounded-full px-5 py-1.5 text-sm font-medium transition-all duration-300 ${
            activeTab === "albums"
              ? "bg-card text-foreground shadow-sm"
              : "text-muted-foreground hover:text-foreground"
          }`}
        >
          专辑
        </button>
      </div>

      {/* Photos tab — masonry-ish grid */}
      {activeTab === "photos" && (
        <div className="columns-2 gap-3 sm:columns-3 space-y-3">
          {photos.map((photo) => (
            <div
              key={photo.id}
              className={`break-inside-avoid rounded-xl bg-muted/50 flex items-center justify-center text-muted-foreground text-sm overflow-hidden border border-border/40 hover:border-border transition-colors duration-200 ${
                photo.tall ? "aspect-[3/4]" : "aspect-square"
              }`}
            >
              {photo.label}
            </div>
          ))}
        </div>
      )}

      {/* Albums tab — vinyl record grid */}
      {activeTab === "albums" && (
        <div className="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4">
          {albums.map((album) => (
            <div key={album.id} className="group space-y-2">
              <div className="aspect-square rounded-lg bg-muted/50 border border-border/40 flex items-center justify-center text-muted-foreground text-xs overflow-hidden group-hover:border-border group-hover:shadow-md transition-all duration-300">
                Cover
              </div>
              <div className="px-0.5">
                <p className="text-sm font-medium text-foreground truncate leading-tight">
                  {album.title}
                </p>
                <p className="text-xs text-muted-foreground truncate">
                  {album.artist}
                </p>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  );
};

export default Gallery;
